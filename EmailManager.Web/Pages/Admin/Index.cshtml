@page
@model EmailManager.Web.Pages.Admin.IndexModel
@{
    ViewData["Title"] = "Yönetici Paneli";
}

<!-- Dashboard Stats -->
<div class="row g-4 mb-4">
    <!-- Stat Card 1 -->
    <div class="col-12 col-md-4">
        <div class="card border-0 shadow-sm bg-gradient-indigo text-white h-100">
            <div class="card-body p-4 d-flex align-items-center justify-content-between">
                <div>
                    <h6 class="text-white-50 text-uppercase mb-1 fw-semibold" style="font-size: 0.75rem; letter-spacing: 0.05em;">Toplam Kullanıcı</h6>
                    <h2 class="mb-0 fw-bold">@Model.TotalUsersCount</h2>
                    <div class="mt-2 small text-white-50">
                        <span>Admin: @Model.AdminUsersCount</span> | <span>Kullanıcı: @Model.RegularUsersCount</span>
                    </div>
                </div>
                <div class="bg-white-10 rounded-circle p-3">
                    <i class="bi bi-people-fill" style="font-size: 2.2rem;"></i>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Stat Card 2 -->
    <div class="col-12 col-md-4">
        <div class="card border-0 shadow-sm bg-gradient-emerald text-white h-100">
            <div class="card-body p-4 d-flex align-items-center justify-content-between">
                <div>
                    <h6 class="text-white-50 text-uppercase mb-1 fw-semibold" style="font-size: 0.75rem; letter-spacing: 0.05em;">Güvenli Dahili Posta</h6>
                    <h2 class="mb-0 fw-bold">@Model.TotalInternalMailsCount</h2>
                    <div class="mt-2 small text-white-50">
                        <i class="bi bi-shield-fill-check me-1"></i> AES-256 Şifreli
                    </div>
                </div>
                <div class="bg-white-10 rounded-circle p-3">
                    <i class="bi bi-shield-lock-fill" style="font-size: 2.2rem;"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- Stat Card 3 -->
    <div class="col-12 col-md-4">
        <div class="card border-0 shadow-sm bg-gradient-violet text-white h-100">
            <div class="card-body p-4 d-flex align-items-center justify-content-between">
                <div>
                    <h6 class="text-white-50 text-uppercase mb-1 fw-semibold" style="font-size: 0.75rem; letter-spacing: 0.05em;">Dış Posta Gönderimleri (SMTP)</h6>
                    <h2 class="mb-0 fw-bold">@Model.TotalExternalMailsCount</h2>
                    <div class="mt-2 small text-white-50">
                        <i class="bi bi-cloud-arrow-up-fill me-1"></i> Mailpit / SMTP
                    </div>
                </div>
                <div class="bg-white-10 rounded-circle p-3">
                    <i class="bi bi-envelope-paper-fill" style="font-size: 2.2rem;"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Main Section -->
<div class="row g-4">
    <!-- Son Kayıt Olanlar -->
    <div class="col-12 col-lg-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white py-3">
                <h6 class="mb-0 fw-bold text-slate-800"><i class="bi bi-person-plus-fill me-2 text-indigo"></i>Son Kayıt Olanlar</h6>
            </div>
            <div class="card-body p-0">
                @if (!Model.RecentUsers.Any())
                {
                    <div class="text-center py-4 text-muted small">Kullanıcı bulunmuyor.</div>
                }
                else
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var user in Model.RecentUsers)
                        {
                            <li class="list-group-item d-flex align-items-center justify-content-between py-3 border-0 border-bottom">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="bg-light text-indigo rounded-circle d-flex align-items-center justify-content-center" style="width: 38px; height: 38px; font-weight: 600;">
                                        @((user.FirstName?.Length > 0 ? user.FirstName[0].ToString() : "") + (user.LastName?.Length > 0 ? user.LastName[0].ToString() : ""))
                                    </div>
                                    <div>
                                        <h6 class="mb-0 fw-semibold text-slate-800" style="font-size: 0.85rem;">@user.FullName</h6>
                                        <span class="text-muted small">@user.Email</span>
                                    </div>
                                </div>
                                <span class="small text-muted">@user.CreatedAt.ToString("dd.MM.yyyy")</span>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>

    <!-- Son Dahili E-postalar -->
    <div class="col-12 col-lg-8">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                <h6 class="mb-0 fw-bold text-slate-800"><i class="bi bi-shield-lock-fill me-2 text-success"></i>Son Güvenli Dahili Postalar</h6>
                <a href="/Admin/AllMails" class="btn btn-link btn-sm text-indigo p-0 text-decoration-none">Tümünü Gör</a>
            </div>
            <div class="card-body p-0">
                @if (!Model.RecentInternalMails.Any())
                {
                    <div class="text-center py-5 text-muted small">Henüz dahili posta gönderilmemiş.</div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Kimden</th>
                                    <th>Kime</th>
                                    <th>Tarih</th>
                                    <th class="text-center">Durum</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var mail in Model.RecentInternalMails)
                                {
                                    <tr>
                                        <td class="text-truncate" style="max-width: 150px;">@mail.FromEmail</td>
                                        <td class="text-truncate" style="max-width: 150px;">@mail.ToEmail</td>
                                        <td class="small text-muted">@mail.SentAt.ToString("g")</td>
                                        <td class="text-center">
                                            @if (mail.IsRead)
                                            {
                                                <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill">Okundu</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-warning-subtle text-warning border border-warning-subtle rounded-pill">Okunmadı</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .text-indigo { color: #6366f1; }
        .text-slate-800 { color: #1e293b; }
        
        .bg-gradient-indigo {
            background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%);
        }
        .bg-gradient-emerald {
            background: linear-gradient(135deg, #10b981 0%, #059669 100%);
        }
        .bg-gradient-violet {
            background: linear-gradient(135deg, #8b5cf6 0%, #7c3aed 100%);
        }
        .bg-white-10 {
            background: rgba(255, 255, 255, 0.15);
        }
    </style>
}
