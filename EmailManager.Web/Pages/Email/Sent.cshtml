@page
@model EmailManager.Web.Pages.Email.SentModel
@{
    ViewData["Title"] = "Gönderilenler";
}

<div class="row">
    <div class="col-12">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                <h5 class="mb-0 text-slate-800 fw-bold"><i class="bi bi-send-fill text-indigo me-2"></i>Gönderilenler</h5>
                <div class="text-muted small">
                    Toplam: @Model.TotalCount mesaj
                </div>
            </div>
            <div class="card-body p-0">
                @if (!Model.Mails.Any())
                {
                    <div class="text-center py-5">
                        <i class="bi bi-send text-muted" style="font-size: 3rem;"></i>
                        <h6 class="text-muted mt-3">Gönderilmiş e-posta bulunmuyor.</h6>
                        <p class="text-muted small">Gönderdiğiniz tüm güvenli ptop.com e-postaları burada listelenecektir.</p>
                        <a href="/Email/Send" class="btn btn-primary btn-sm mt-2">
                            <i class="bi bi-pencil-square me-1"></i> İlk E-postayı Gönder
                        </a>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0" style="table-layout: fixed;">
                            <thead class="table-light">
                                <tr>
                                    <th style="width: 25%;">Alıcı</th>
                                    <th style="width: 50%;">Konu</th>
                                    <th style="width: 25%;">Tarih</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var mail in Model.Mails)
                                {
                                    <tr style="cursor: pointer; transition: background 0.15s ease;"
                                        onclick="viewSentMail(@mail.Id)">
                                        <td class="text-truncate">
                                            <i class="bi bi-arrow-right text-success me-2"></i>
                                            @mail.ToEmail
                                        </td>
                                        <td class="text-truncate text-dark fw-medium">
                                            @mail.Subject
                                        </td>
                                        <td class="small text-muted text-truncate">
                                            @mail.SentAt.ToString("g")
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <!-- Pagination -->
                    @if (Model.TotalPages > 1)
                    {
                        <div class="d-flex justify-content-center border-top py-3">
                            <nav>
                                <ul class="pagination pagination-sm mb-0">
                                    <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                                        <a class="page-link" href="?page=@(Model.CurrentPage - 1)">Önceki</a>
                                    </li>
                                    @for (int i = 1; i <= Model.TotalPages; i++)
                                    {
                                        <li class="page-item @(Model.CurrentPage == i ? "active" : "")">
                                            <a class="page-link" href="?page=@i">@i</a>
                                        </li>
                                    }
                                    <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                                        <a class="page-link" href="?page=@(Model.CurrentPage + 1)">Sonraki</a>
                                    </li>
                                </ul>
                            </nav>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

<!-- Mail View Modal -->
<div class="modal fade" id="viewSentMailModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 16px;">
            <div class="modal-header border-bottom-0 pb-0">
                <span class="badge bg-primary-subtle text-primary border border-primary-subtle rounded-pill px-3 py-1 text-uppercase" style="font-size: 0.7rem;">
                    <i class="bi bi-shield-lock-fill me-1"></i> AES-256 Şifreli Posta
                </span>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body pt-3 px-4">
                <h4 class="fw-bold mb-3 text-slate-900" id="modal-subject">...</h4>
                
                <div class="d-flex align-items-center gap-3 border-bottom pb-3 mb-4">
                    <div class="bg-indigo-subtle text-indigo rounded-circle d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                        <i class="bi bi-person-fill" style="font-size: 1.5rem;"></i>
                    </div>
                    <div class="flex-grow-1 min-w-0">
                        <div class="d-flex justify-content-between align-items-baseline">
                            <h6 class="mb-0 fw-bold text-slate-800 text-truncate" id="modal-from">...</h6>
                            <span class="text-muted small" id="modal-date">...</span>
                        </div>
                        <div class="text-muted small text-truncate" id="modal-to">Kime: ...</div>
                    </div>
                </div>

                <div class="mail-body-content text-slate-700 bg-light p-3 rounded-3" style="min-height: 200px; white-space: pre-wrap; overflow-y: auto; max-height: 400px;" id="modal-body">
                    ...
                </div>
            </div>
            <div class="modal-footer border-top-0 pt-0 px-4 pb-4">
                <button type="button" class="btn btn-secondary btn-sm rounded-3" data-bs-dismiss="modal">Kapat</button>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .text-indigo { color: #6366f1; }
        .bg-indigo-subtle { background-color: rgba(99, 102, 241, 0.1); }
        .text-slate-800 { color: #1e293b; }
        .text-slate-900 { color: #0f172a; }
        .table-hover tbody tr:hover {
            background-color: rgba(99, 102, 241, 0.04) !important;
        }
    </style>
}

@section Scripts {
    <script>
        let sentMailModal;
        document.addEventListener("DOMContentLoaded", () => {
            sentMailModal = new bootstrap.Modal(document.getElementById('viewSentMailModal'));
        });

        async function viewSentMail(id) {
            try {
                const response = await fetch(`?handler=Details&id=${id}`);
                if (!response.ok) {
                    showToast("Mesaj detayları alınamadı.", "error");
                    return;
                }
                const data = await response.json();
                
                document.getElementById('modal-subject').innerText = data.subject;
                document.getElementById('modal-from').innerText = data.fromEmail;
                document.getElementById('modal-to').innerText = `Kime: ${data.toEmail}`;
                document.getElementById('modal-date').innerText = data.sentAt;

                const bodyEl = document.getElementById('modal-body');
                if (data.isHtml) {
                    bodyEl.innerHTML = data.body;
                } else {
                    bodyEl.textContent = data.body;
                }

                sentMailModal.show();
            } catch (err) {
                console.error(err);
                showToast("Sistem hatası.", "error");
            }
        }
    </script>
}
