@page
@model EmailManager.Web.Pages.Email.HistoryModel
@using EmailManager.Domain.Enums
@{
    ViewData["Title"] = "Gönderim Geçmişi";
}

<div class="card">
    <div class="card-header d-flex align-items-center justify-content-between">
        <span><i class="bi bi-clock-history text-primary me-2"></i>Gönderim Geçmişi</span>
        <span class="text-muted" style="font-size: 0.8rem; font-weight: 400;">
            Toplam <strong>@Model.TotalCount</strong> kayıt
        </span>
    </div>
    <div class="card-body p-0">
        @if (!Model.Logs.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-inbox text-muted" style="font-size: 3rem;"></i>
                <p class="text-muted mt-3">Henüz gönderim kaydı bulunmuyor.</p>
                <a href="/Email/Send" class="btn btn-primary btn-sm mt-1">
                    <i class="bi bi-send me-1"></i>İlk e-postanı gönder
                </a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0" style="font-size: 0.875rem;">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4" style="width: 60px;">#</th>
                            <th>Alıcı</th>
                            <th>Konu</th>
                            <th>Durum</th>
                            <th>Tarih</th>
                            <th style="width: 80px;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in Model.Logs)
                        {
                            <tr>
                                <td class="ps-4 text-muted">@log.Id</td>
                                <td>
                                    <span class="fw-medium">@log.To</span>
                                </td>
                                <td class="text-truncate" style="max-width: 200px;" title="@log.Subject">
                                    @log.Subject
                                </td>
                                <td>
                                    @{
                                        var (badgeClass, icon, label) = log.Status switch
                                        {
                                            EmailStatus.Sent    => ("badge-sent",    "bi-check-circle-fill", "Gönderildi"),
                                            EmailStatus.Failed  => ("badge-failed",  "bi-x-circle-fill",    "Başarısız"),
                                            EmailStatus.Pending => ("badge-pending", "bi-hourglass-split",  "Bekliyor"),
                                            _                   => ("bg-secondary",  "bi-question-circle",  "Bilinmiyor")
                                        };
                                    }
                                    <span class="badge @badgeClass px-2 py-1">
                                        <i class="bi @icon me-1"></i>@label
                                    </span>
                                </td>
                                <td class="text-muted">
                                    <span title="@log.SentAt.ToString("dd.MM.yyyy HH:mm:ss") UTC">
                                        @log.SentAt.ToString("dd.MM.yyyy HH:mm")
                                    </span>
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(log.ErrorMessage))
                                    {
                                        <button type="button"
                                                class="btn btn-sm btn-outline-danger py-0 px-2"
                                                data-bs-toggle="tooltip"
                                                data-bs-placement="left"
                                                title="@log.ErrorMessage">
                                            <i class="bi bi-info-circle"></i>
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Sayfalama -->
            @if (Model.TotalPages > 1)
            {
                <div class="d-flex justify-content-between align-items-center px-4 py-3 border-top">
                    <span class="text-muted small">
                        Sayfa @Model.CurrentPage / @Model.TotalPages
                    </span>
                    <nav aria-label="Sayfalama">
                        <ul class="pagination pagination-sm mb-0">
                            <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : "")">
                                <a class="page-link" href="?page=@(Model.CurrentPage - 1)">
                                    <i class="bi bi-chevron-left"></i>
                                </a>
                            </li>
                            @for (int i = Math.Max(1, Model.CurrentPage - 2);
                                      i <= Math.Min(Model.TotalPages, Model.CurrentPage + 2); i++)
                            {
                                <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                                    <a class="page-link" href="?page=@i">@i</a>
                                </li>
                            }
                            <li class="page-item @(Model.CurrentPage >= Model.TotalPages ? "disabled" : "")">
                                <a class="page-link" href="?page=@(Model.CurrentPage + 1)">
                                    <i class="bi bi-chevron-right"></i>
                                </a>
                            </li>
                        </ul>
                    </nav>
                </div>
            }
        }
    </div>
</div>

@section Scripts {
<script>
    // Bootstrap tooltip'leri aktive et
    const tooltipEls = document.querySelectorAll('[data-bs-toggle="tooltip"]');
    tooltipEls.forEach(el => new bootstrap.Tooltip(el));
</script>
}
