@page
@model EmailManager.Web.Pages.Account.RegisterModel
@{
    Layout = null;
    ViewData["Title"] = "Kayıt Ol";
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Email Manager - Yeni hesap oluştur" />
    <title>Kayıt Ol — Email Manager</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #0f172a 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem 1rem;
        }

        .register-card {
            background: rgba(255,255,255,0.05);
            backdrop-filter: blur(16px);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 20px;
            padding: 2.5rem;
            width: 100%;
            max-width: 460px;
            box-shadow: 0 25px 50px rgba(0,0,0,0.4);
        }

        .register-logo {
            width: 52px; height: 52px;
            background: linear-gradient(135deg, #6366f1, #8b5cf6);
            border-radius: 14px;
            display: flex; align-items: center; justify-content: center;
            margin: 0 auto 1.25rem;
        }
        .register-logo i { font-size: 1.6rem; color: #fff; }

        .register-title {
            color: #f8fafc; font-size: 1.4rem; font-weight: 700;
            text-align: center; margin-bottom: 0.2rem;
        }
        .register-subtitle {
            color: #64748b; font-size: 0.875rem;
            text-align: center; margin-bottom: 1.75rem;
        }

        .form-label { color: #94a3b8; font-size: 0.8rem; font-weight: 500; margin-bottom: 0.35rem; }

        .form-control {
            background: rgba(255,255,255,0.07);
            border: 1px solid rgba(255,255,255,0.12);
            color: #f1f5f9; border-radius: 10px;
            padding: 0.65rem 1rem; transition: all 0.2s;
            font-size: 0.9rem;
        }
        .form-control:focus {
            background: rgba(255,255,255,0.1);
            border-color: #6366f1; color: #f1f5f9;
            box-shadow: 0 0 0 3px rgba(99,102,241,0.25);
        }
        .form-control::placeholder { color: #475569; }
        .form-control.is-invalid { border-color: #ef4444; }

        /* E-posta prefix input grubu */
        .email-group { display: flex; gap: 0; }
        .email-group .form-control {
            border-radius: 10px 0 0 10px;
            flex: 1;
        }
        .email-suffix {
            background: rgba(99,102,241,0.15);
            border: 1px solid rgba(255,255,255,0.12);
            border-left: none;
            border-radius: 0 10px 10px 0;
            color: #6366f1; font-size: 0.875rem; font-weight: 600;
            padding: 0.65rem 0.9rem;
            display: flex; align-items: center; white-space: nowrap;
        }

        .btn-register {
            background: linear-gradient(135deg, #6366f1, #8b5cf6);
            border: none; color: #fff; font-weight: 600;
            padding: 0.75rem; border-radius: 10px;
            width: 100%; font-size: 0.9375rem; transition: all 0.2s;
        }
        .btn-register:hover {
            transform: translateY(-1px);
            box-shadow: 0 8px 25px rgba(99,102,241,0.4);
            color: #fff;
        }
        .btn-register:disabled { opacity: 0.7; transform: none; }

        .divider {
            display: flex; align-items: center; gap: 1rem;
            margin: 1.25rem 0;
        }
        .divider::before, .divider::after {
            content: ''; flex: 1; height: 1px;
            background: rgba(255,255,255,0.08);
        }
        .divider span { color: #475569; font-size: 0.8rem; }

        .login-link {
            text-align: center; margin-top: 0.25rem;
        }
        .login-link a {
            color: #6366f1; text-decoration: none; font-weight: 500;
            font-size: 0.9rem; transition: color 0.2s;
        }
        .login-link a:hover { color: #818cf8; }

        .alert-danger {
            background: rgba(254,226,226,0.1);
            border: 1px solid rgba(239,68,68,0.3);
            color: #fca5a5; border-radius: 10px;
            font-size: 0.875rem;
        }

        .preview-email {
            background: rgba(99,102,241,0.1);
            border: 1px solid rgba(99,102,241,0.25);
            border-radius: 8px; padding: 0.5rem 0.85rem;
            font-size: 0.82rem; color: #a5b4fc;
            margin-top: 0.4rem; display: none;
            align-items: center; gap: 0.4rem;
        }
        .preview-email.visible { display: flex; }
    </style>
</head>
<body>
<div class="register-card">
    <div class="register-logo">
        <i class="bi bi-person-plus-fill"></i>
    </div>
    <h1 class="register-title">Hesap Oluştur</h1>
    <p class="register-subtitle">Ptop Mail sistemine hoş geldin</p>

    @if (!ModelState.IsValid && ModelState.ErrorCount > 0)
    {
        <div class="alert alert-danger mb-3">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>
            @foreach (var error in ModelState.Values.SelectMany(v => v.Errors).Take(3))
            {
                <div>@error.ErrorMessage</div>
            }
        </div>
    }

    <form method="post" id="registerForm" novalidate>
        <!-- Ad / Soyad -->
        <div class="row g-2 mb-3">
            <div class="col-6">
                <label asp-for="Input.FirstName" class="form-label">Ad</label>
                <input asp-for="Input.FirstName" id="firstName" class="form-control"
                       placeholder="Fatih" autocomplete="given-name" />
                <span asp-validation-for="Input.FirstName" class="text-danger" style="font-size:0.78rem;"></span>
            </div>
            <div class="col-6">
                <label asp-for="Input.LastName" class="form-label">Soyad</label>
                <input asp-for="Input.LastName" id="lastName" class="form-control"
                       placeholder="Şahin" autocomplete="family-name" />
                <span asp-validation-for="Input.LastName" class="text-danger" style="font-size:0.78rem;"></span>
            </div>
        </div>

        <!-- E-posta ön eki -->
        <div class="mb-3">
            <label asp-for="Input.EmailPrefix" class="form-label">
                E-posta Adresi
            </label>
            <div class="email-group">
                <input asp-for="Input.EmailPrefix" id="emailPrefix" class="form-control"
                       placeholder="ad.soyad" autocomplete="username"
                       style="text-transform: lowercase;" />
                <span class="email-suffix">@@ptop.com</span>
            </div>
            <div class="preview-email" id="emailPreview">
                <i class="bi bi-envelope-fill"></i>
                <span id="emailPreviewText"></span>
            </div>
            <span asp-validation-for="Input.EmailPrefix" class="text-danger" style="font-size:0.78rem;"></span>
        </div>

        <!-- Şifre -->
        <div class="mb-3">
            <label asp-for="Input.Password" class="form-label">Şifre</label>
            <input asp-for="Input.Password" id="password" type="password"
                   class="form-control" placeholder="Min. 8 karakter, büyük harf ve rakam"
                   autocomplete="new-password" />
            <span asp-validation-for="Input.Password" class="text-danger" style="font-size:0.78rem;"></span>
        </div>

        <!-- Şifre Tekrar -->
        <div class="mb-4">
            <label asp-for="Input.ConfirmPassword" class="form-label">Şifre Tekrar</label>
            <input asp-for="Input.ConfirmPassword" id="confirmPassword" type="password"
                   class="form-control" placeholder="Şifrenizi tekrar girin"
                   autocomplete="new-password" />
            <span asp-validation-for="Input.ConfirmPassword" class="text-danger" style="font-size:0.78rem;"></span>
        </div>

        <button type="submit" id="registerBtn" class="btn btn-register">
            <span id="registerBtnText">
                <i class="bi bi-person-check me-2"></i>Kayıt Ol
            </span>
            <span id="registerBtnLoading" class="d-none">
                <span class="spinner-border spinner-border-sm me-2"></span>Hesap oluşturuluyor...
            </span>
        </button>
    </form>

    <div class="divider"><span>veya</span></div>

    <div class="login-link">
        <a href="/Account/Login">
            <i class="bi bi-box-arrow-in-right me-1"></i>
            Zaten hesabın var mı? Giriş yap
        </a>
    </div>
</div>

<script>
    // E-posta önizlemesi
    const prefixInput = document.getElementById('emailPrefix');
    const preview = document.getElementById('emailPreview');
    const previewText = document.getElementById('emailPreviewText');

    prefixInput.addEventListener('input', function () {
        const val = this.value.toLowerCase().trim();
        this.value = val;
        if (val.length > 0) {
            previewText.textContent = val + '\u0040ptop.com';
            preview.classList.add('visible');
        } else {
            preview.classList.remove('visible');
        }
    });

    // Submit loading state
    document.getElementById('registerForm').addEventListener('submit', function () {
        document.getElementById('registerBtnText').classList.add('d-none');
        document.getElementById('registerBtnLoading').classList.remove('d-none');
        document.getElementById('registerBtn').disabled = true;
    });
</script>
</body>
</html>
